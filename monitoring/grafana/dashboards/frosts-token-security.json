    {
      "title": "Token Refresh Alert Level Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch" },
      "targets": [
        {
          "datasource": { "type": "elasticsearch" },
          "query": "{\"bucketAggs\":[{\"field\":\"@timestamp\",\"id\":\"2\",\"settings\":{\"interval\":\"auto\"},\"type\":\"date_histogram\"}],\"metrics\":[{\"id\":\"1\",\"type\":\"count\"}],\"query\":\"alert_level:*\",\"timeField\":\"@timestamp\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
