# Error Reporting
# Set to "true" to enable error reporting in any environment
# Set to "false" to disable error reporting even in production
# Default: enabled in production (VITE_MODE=production), disabled in development
VITE_ERROR_REPORT_ENABLED=

# Performance Sampling Rate (1-100)
# Percentage of users that will report Web Vitals data
# Default: 100 (all users report)
# Example: 10 means only ~10% of sessions will report performance metrics
VITE_PERF_SAMPLING_RATE=
